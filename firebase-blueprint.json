{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user information, subscription status, and credit balance.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "credits": { "type": "number" },
        "subscription": {
          "type": "object",
          "properties": {
            "plan": { "type": "string", "enum": ["free", "pro", "premium"] },
            "expiresAt": { "type": "string", "format": "date-time" },
            "active": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "credits"]
    },
    "Note": {
      "title": "AI Note",
      "description": "A note generated by the AI Note Maker.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "sourceType": { "type": "string", "enum": ["text", "pdf", "video"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "content"]
    },
    "Quiz": {
      "title": "AI Quiz",
      "description": "A quiz generated by the AI Quiz Generator.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "topic": { "type": "string" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "string" },
              "explanation": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "FlashcardDeck": {
      "title": "Flashcard Deck",
      "description": "A deck of flashcards.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "cards": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "front": { "type": "string" },
              "back": { "type": "string" },
              "lastReviewed": { "type": "string", "format": "date-time" },
              "interval": { "type": "number" }
            }
          }
        }
      }
    },
    "UsageLog": {
      "title": "Usage Log",
      "description": "Tracks tool usage for admin analytics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "tool": { "type": "string" },
        "creditsUsed": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Task": {
      "title": "Study Task",
      "description": "A task in the study planner.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "deadline": { "type": "string", "format": "date" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "LoginLog": {
      "title": "Login Log",
      "description": "Tracks user login events.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Saved AI notes."
    },
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Generated quizzes."
    },
    "/flashcards/{deckId}": {
      "schema": "FlashcardDeck",
      "description": "User flashcard decks."
    },
    "/usageLogs/{logId}": {
      "schema": "UsageLog",
      "description": "Admin usage tracking logs."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "User study tasks."
    },
    "/loginLogs/{logId}": {
      "schema": "LoginLog",
      "description": "User login event logs."
    }
  }
}
